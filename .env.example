# =============================================
# LiteLLM（Chat Completion；請填助教提供之值）
# =============================================
LITELLM_API_KEY=your_api_key_here
# 須與 LITELLM_API_KEY 一併設定；程式會以 OpenAI-compatible 方式呼叫（避免誤走 Vertex）
LITELLM_BASE_URL=https://your-litellm-endpoint.example.com
# 可選：預設模型（與 rag_query / skill_builder 一致）
LITELLM_MODEL=gemini-2.5-flash

# =============================================
# Embedding：sentence-transformers 本地（免費）
# =============================================
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# =============================================
# Chroma 持久化目錄（相對於專案根目錄）
# =============================================
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=OG_rag

# =============================================
# 可選：chunk 參數
# =============================================
# CHUNK_SIZE=600
# CHUNK_OVERLAP=100

# =============================================
# 可選：RAG 檢索過濾（cosine distance，0=完全相同，1=完全不似）
# =============================================
# MAX_DISTANCE=0.65
